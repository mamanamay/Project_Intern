# ─── ทั่วไป ─────────────────────────────────────────
NODE_ENV=development

# ─── ฐานข้อมูล ────────────────────────────────────────
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=appdb
DB_USERNAME=appuser
DB_PASSWORD=changeme

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── การยืนยันตัวตน ────────────────────────────────────────
JWT_SECRET=เปลี่ยนเป็นค่าที่ซับซ้อนและยาวอย่างน้อย-32-ตัวอักษร
JWT_EXPIRES_IN=7d

# ─── Frontend ──────────────────────────────────────
VITE_API_URL=https://localhost/api

# ─── CORS ────────────────────────────────────────────
ALLOWED_ORIGIN=https://localhost
